<!-- Dark mode toggle — sun/moon icon, persists in localStorage -->
<!-- Uses CSS dark: variants for icons so both desktop+mobile instances work -->
<button
  class="dark-toggle p-2 text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
  aria-label="Activar modo oscuro"
>
  <!-- Moon (shown in light mode) -->
  <svg class="w-4 h-4 dark:hidden" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
  </svg>
  <!-- Sun (shown in dark mode) -->
  <svg class="w-4 h-4 hidden dark:block" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
  </svg>
</button>

<script>
  const html = document.documentElement;

  function setDark(dark: boolean) {
    html.classList.toggle('dark', dark);
    document.querySelectorAll<HTMLButtonElement>('.dark-toggle').forEach(btn => {
      btn.setAttribute('aria-label', dark ? 'Activar modo claro' : 'Activar modo oscuro');
    });
    localStorage.setItem('theme', dark ? 'dark' : 'light');
  }

  // Init: only respect explicit user preference, never system preference
  setDark(localStorage.getItem('theme') === 'dark');

  document.querySelectorAll<HTMLButtonElement>('.dark-toggle').forEach(btn => {
    btn.addEventListener('click', () => setDark(!html.classList.contains('dark')));
  });
</script>
