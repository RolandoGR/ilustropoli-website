---
interface TagOption {
  value: string;
  label: string;
  count: number;
}

interface Props {
  categories: string[];
  counts: Record<string, number>;
  total: number;
  tags?: TagOption[];
}

const { categories, counts, total, tags = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  acuarela: 'Acuarela',
  acrilico: 'Acrílico',
  sketch: 'Sketch',
};
---

<div id="filter-bar" class="flex flex-wrap gap-2 mb-8">
  <button
    class="filter-btn active text-xs px-4 py-1.5 border transition-colors"
    data-filter="all"
  >
    Todo <span class="opacity-50 ml-1">{total}</span>
  </button>

  {categories.map(cat => (
    <button
      class="filter-btn text-xs px-4 py-1.5 border transition-colors"
      data-filter={cat}
      data-filter-type="category"
    >
      {categoryLabels[cat] ?? cat}
      <span class="opacity-50 ml-1">{counts[cat] ?? 0}</span>
    </button>
  ))}

  {tags.length > 0 && (
    <span class="self-center border-l border-stone-200 dark:border-stone-700 h-4 mx-1"></span>
  )}

  {tags.map(tag => (
    <button
      class="filter-btn text-xs px-4 py-1.5 border transition-colors"
      data-filter={tag.value}
      data-filter-type="tag"
    >
      {tag.label}
      <span class="opacity-50 ml-1">{tag.count}</span>
    </button>
  ))}
</div>

<style>
  .filter-btn {
    border-color: #d6d3d1;
    color: #78716c;
    background: transparent;
  }
  .filter-btn:hover {
    border-color: #44403c;
    color: #1c1917;
  }
  .filter-btn.active {
    border-color: #1c1917;
    background: #1c1917;
    color: #fafaf9;
  }
</style>

<script>
  const btns  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('[data-category-item]');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      const type   = btn.dataset.filterType; // 'category' | 'tag' | undefined (all)

      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      cards.forEach(card => {
        let show = false;
        if (filter === 'all') {
          show = true;
        } else if (type === 'category') {
          show = card.dataset.categoryItem === filter;
        } else if (type === 'tag') {
          const itemTags = (card.dataset.tags ?? '').split(',').map(t => t.trim()).filter(Boolean);
          show = itemTags.includes(filter);
        }
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
